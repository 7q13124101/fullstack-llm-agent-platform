# fullstack_llm_agent_platform Environment Variables

# === Project ===
PROJECT_NAME=fullstack_llm_agent_platform
DEBUG=true
ENVIRONMENT=local
TIMEZONE=  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache
# === Logfire ===
# Get your token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=fullstack_llm_agent_platform
LOGFIRE_ENVIRONMENT=development
# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fullstack_llm_agent_platform
# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key
# === RAG Configuration ===
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_CHUNKING_STRATEGY=recursive  # recursive, markdown, or fixed
RAG_HYBRID_SEARCH=false  # Enable BM25 + vector hybrid search
RAG_ENABLE_OCR=false  # OCR fallback for scanned PDFs (requires tesseract-ocr installed)# Vector Database (pgvector) — uses existing PostgreSQL connection# Reranker
HF_TOKEN=
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2# Google Drive (service account)
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials/google-drive-sa.json

# === AI Agent (langgraph, google) ===GOOGLE_API_KEY=
AI_MODEL=gemini-2.5-flashAI_TEMPERATURE=0.7
# === LangSmith Observability ===
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fullstack_llm_agent_platform
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com# Embeddings# Default OpenAI Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Retrieval
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10

# Reranker
# PDF Parser
# Google Drive (optional, for document ingestion)GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
# === Messaging Channels ===
# Fernet encryption key for bot token storage — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=# Telegram: webhook base URL for production (e.g. https://api.yourdomain.com)
# Leave empty to use long-polling mode (recommended for development)
TELEGRAM_WEBHOOK_BASE_URL=
# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
# === Docker Production (Traefik) ===
# Domain for production deployment
DOMAIN=example.com

# Let's Encrypt email for SSL certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...